{
  "name": "seleya",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "description": "Self-hosted dashboard that aggregates open GitHub issues and pull requests across many repositories and organizations into configurable tabs and groups.",
  "keywords": [
    "github",
    "issues",
    "pull-requests",
    "dashboard",
    "self-hosted",
    "triage"
  ],
  "homepage": "https://github.com/joeyparrish/seleya#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joeyparrish/seleya.git"
  },
  "bugs": {
    "url": "https://github.com/joeyparrish/seleya/issues"
  },
  "author": "Joey Parrish <joey.parrish@gmail.com>",
  "engines": { "node": "^20.19.0 || >=22.12.0" },
  "bin": { "seleya": "dist/server/cli.js" },
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "build:server": "tsc -p tsconfig.json",
    "build:client": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:client": "tsc -p tsconfig.client.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync": "tsx src/server/cli.ts",
    "start": "tsx src/server/server.ts",
    "dev": "tsx watch src/server/server.ts",
    "dev:client": "vite"
  },
  "dependencies": {
    "@mantine/core": "^9.0.0",
    "@mantine/hooks": "^9.0.0",
    "@octokit/graphql": "^8.1.1",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-table": "^8.20.0",
    "better-sqlite3": "^11.3.0",
    "express": "^4.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.0",
    "globals": "^15.11.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
